---

<section id="projekty" class="py-28 bg-[#08080c] border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center sm:text-left space-y-2">
      <h2 class="text-xs font-bold uppercase tracking-widest text-indigo-400">Wybrane Wdrożenia & Portfolio</h2>
      <p class="text-3xl sm:text-5xl font-black uppercase italic tracking-tighter text-white">
        Wybrane Realizacje i Projekty
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((pro) => (
        <div class="group rounded-[2.5rem] bg-[#11111c] border border-white/10 overflow-hidden hover:border-indigo-500/50 transition-all flex flex-col justify-between">
          <div>
            <div class="aspect-video overflow-hidden bg-white/5 relative">
              <img src={pro.image} alt={pro.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-8 space-y-4">
              <div class="text-xs font-bold uppercase tracking-widest text-indigo-400">{pro.meta}</div>
              <h3 class="text-xl font-black uppercase italic text-white">{pro.title}</h3>
              <ul class="text-xs text-white/70 space-y-2 list-disc pl-4 font-medium">
                {pro.bullets_pl.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
          {pro.link && (
            <div class="p-8 pt-0">
              <a href={pro.link} target="_blank" rel="noreferrer" class="inline-block px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-white text-xs font-bold uppercase tracking-widest hover:bg-indigo-600 hover:border-indigo-600 transition-colors">
                Zobacz Stronę →
              </a>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
