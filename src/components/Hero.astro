---
---
<section class="pt-36 pb-20 overflow-hidden bg-gradient-to-b from-[#08080c] via-[#0d0d16] to-[#08080c]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 space-y-8 text-left">
        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white leading-tight">
          CZEŚĆ, JESTEM <br />
          <span class="inline-block pr-6 text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-indigo-600">
            ALEKSANDER
          </span>
        </h1>
        <p class="text-base sm:text-lg text-white/70 font-medium max-w-xl leading-relaxed">
          Web Developer & Specjalista WordPress z ponad 7-letnim doświadczeniem w tworzeniu dedykowanych motywów, wtyczek oraz szybkich i skalowalnych aplikacji webowych.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="/cv" class="px-8 py-4 rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-xs uppercase tracking-widest hover:bg-white/10 transition-colors">
            Zobacz CV
          </a>
        </div>
      </div>
      <div class="lg:col-span-5 flex justify-center">
        <div class="w-72 h-72 sm:w-96 sm:h-96 rounded-[2.5rem] overflow-hidden drop-shadow-2xl">
          <img src="/assets/aleksander.png" alt="Aleksander Banaszak" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </div>
</section>
