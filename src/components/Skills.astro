---
const skillGroups = [
  {
    category: "Development & WordPress",
    skills: ["HTML5", "CSS3", "SCSS", "JavaScript", "PHP", "WordPress API", "WooCommerce", "REST API", "ACF Pro"]
  },
  {
    category: "Full-Stack & Frameworks",
    skills: ["Astro", "TailwindCSS", "React", "MySQL", "Git", "Linux CLI", "Nginx", "Server Management"]
  },
  {
    category: "Marketing & Ads",
    skills: ["Google Ads", "Banner Ads", "SEO", "Marketing Automation", "Sklepy e-commerce"]
  }
];
---

<section id="umiejetnosci" class="py-28 bg-[#08080c] border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <h2 class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-2">Umiejetnosci & Technologie</h2>
      <p class="text-3xl sm:text-5xl font-black uppercase italic tracking-tighter text-white">
        Stack Techniczny & Kluczowe Kompetencje
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {skillGroups.map((group) => (
        <div class="p-8 sm:p-12 rounded-[2.5rem] bg-[#11111c] border border-white/10 space-y-6">
          <h3 class="text-lg font-black uppercase italic text-indigo-400">{group.category}</h3>
          <div class="flex flex-wrap gap-2.5">
            {group.skills.map((skill) => (
              <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
